<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>대륙별 국가 이름 맞히기</title>
<style>
:root{
  --ocean:#E9F2F6; --grid:#D9E7EE;
  --ink:#17324A; --blue:#2265A3; --blue-deep:#174B7D; --blue-soft:#CBE0F0;
  --sun:#F5B21A; --sun-soft:#FFF3D6;
  --coral:#D95D39; --coral-soft:#F8D9CD;
  --green:#2E8B57; --green-soft:#CDEBDA;
  --paper:#FFFFFF; --line:#C6D8E2; --land:#FDFDFB;
  --radius:16px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  font-family:"Pretendard","Apple SD Gothic Neo","Malgun Gothic","맑은 고딕",sans-serif;
  color:var(--ink);background-color:var(--ocean);
  background-image:linear-gradient(var(--grid) 1px,transparent 1px),linear-gradient(90deg,var(--grid) 1px,transparent 1px);
  background-size:56px 56px;min-height:100vh;
}
.wrap{max-width:1120px;margin:0 auto;padding:26px 18px 120px;}
.screen{display:none;}
.screen.active{display:block;animation:fadeUp .3s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

header{text-align:center;margin-bottom:22px;}
.eyebrow{display:inline-block;font-size:13px;font-weight:700;letter-spacing:.28em;color:var(--blue);
  border:1.5px dashed var(--blue);border-radius:999px;padding:6px 16px;margin-bottom:14px;background:var(--paper);}
h1{font-size:clamp(26px,4.5vw,40px);font-weight:900;letter-spacing:-.02em;}
h1 .accent{color:var(--blue);}
.sub{margin-top:8px;color:#4B6579;font-size:15px;}

/* 이름 입력 */
.name-card{
  max-width:520px;margin:0 auto 22px;background:var(--paper);border:2px solid var(--blue);
  border-radius:var(--radius);padding:16px 18px;box-shadow:0 6px 18px rgba(23,50,74,.08);
}
.name-card label{display:block;font-size:13px;font-weight:800;color:var(--blue);letter-spacing:.14em;margin-bottom:8px;}
.name-row{display:flex;gap:8px;}
.name-row input{flex:1;font-size:17px;padding:12px 14px;border:2px solid var(--line);border-radius:10px;font-family:inherit;min-width:0;}
.name-row input:focus{outline:none;border-color:var(--blue);}
.name-hint{margin-top:8px;font-size:12.5px;color:#7A93A6;}

/* 대륙 카드 */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;}
.card{background:var(--paper);border:2px solid var(--line);border-radius:var(--radius);padding:16px;cursor:pointer;
  text-align:left;width:100%;font-family:inherit;color:inherit;
  transition:transform .15s ease,border-color .15s ease,box-shadow .15s ease;}
.card:hover,.card:focus-visible{transform:translateY(-4px);border-color:var(--blue);box-shadow:0 10px 24px rgba(23,50,74,.12);}
.card:focus-visible{outline:3px solid var(--sun);outline-offset:2px;}
.card .thumb{height:150px;border-radius:10px;background:var(--ocean);border:1px solid var(--line);
  display:flex;align-items:center;justify-content:center;overflow:hidden;margin-bottom:12px;}
.card .thumb svg{max-width:94%;max-height:94%;}
.card .row{display:flex;align-items:center;justify-content:space-between;}
.card .cname{font-size:20px;font-weight:800;}
.card .count{font-size:13px;font-weight:700;color:var(--blue-deep);background:var(--ocean);border-radius:999px;padding:4px 12px;}
.card.world{grid-column:1/-1;border-color:var(--sun);background:linear-gradient(135deg,#FFFBEF,#FFF);}
.card.world:hover{border-color:var(--coral);}
.card.world .world-inner{display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.card.world .globe{font-size:44px;line-height:1;}
.card.world .wtitle{font-size:21px;font-weight:900;}
.card.world .wdesc{font-size:13.5px;color:#6A8296;margin-top:4px;}
.card.world .count{background:var(--sun-soft);color:#8A6207;margin-left:auto;}

/* 퀴즈 */
.quiz-head{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:14px;}
.quiz-title{font-size:clamp(21px,3.3vw,29px);font-weight:900;}
.quiz-title small{font-size:13px;font-weight:700;color:var(--blue);display:block;letter-spacing:.18em;margin-bottom:4px;}
.pills{display:flex;gap:8px;flex-wrap:wrap;}
.pill{font-size:14px;font-weight:800;color:var(--blue-deep);background:var(--paper);
  border:2px solid var(--blue);border-radius:999px;padding:7px 14px;}
.pill.name{border-color:var(--sun);color:#8A6207;background:var(--sun-soft);}
.quiz-layout{display:grid;grid-template-columns:1.35fr .65fr;gap:16px;align-items:start;}
@media (max-width:900px){.quiz-layout{grid-template-columns:1fr;}}
.panel{background:var(--paper);border:2px solid var(--line);border-radius:var(--radius);padding:14px;}
.map-panel{background:linear-gradient(180deg,#F2F8FB,#E7F1F6);}
.map-panel svg{width:100%;height:auto;display:block;}

.country{fill:var(--land);stroke:#8AA6B8;stroke-width:1;cursor:pointer;transition:fill .12s ease;}
.country:hover{fill:var(--sun-soft);}
.country.selected{fill:var(--sun);stroke:var(--ink);stroke-width:1.6;}
.country.answered{fill:var(--blue-soft);stroke:var(--blue);}
.country.answered.selected{fill:var(--sun);}
.country.ok{fill:var(--green-soft);stroke:var(--green);cursor:default;}
.country.bad{fill:var(--coral-soft);stroke:var(--coral);cursor:default;}
.country.none{fill:#EDEDE8;stroke:#B7C6D0;cursor:default;}
.grayland{fill:#E3E6E3;stroke:#B9C4CB;stroke-width:1;pointer-events:none;}
.tinydot{cursor:pointer;stroke-width:1.4;}
.namelabel{font-size:11px;font-weight:700;fill:#2C4A63;pointer-events:none;paint-order:stroke;stroke:#fff;stroke-width:3px;stroke-linejoin:round;}

.side-sticky{position:sticky;top:12px;}
.ask-box{min-height:120px;}
.ask-empty{color:#7A93A6;font-size:15px;line-height:1.6;padding:8px 2px;}
.ask-label{font-size:13px;font-weight:800;color:var(--blue);letter-spacing:.14em;margin-bottom:8px;}
.ask-q{font-size:17px;font-weight:800;margin-bottom:10px;}
.input-row{display:flex;gap:8px;}
.input-row input{flex:1;font-size:17px;padding:11px 13px;border:2px solid var(--line);border-radius:10px;font-family:inherit;min-width:0;}
.input-row input:focus{outline:none;border-color:var(--blue);}
.btn{font-family:inherit;font-size:15px;font-weight:800;border:none;border-radius:10px;padding:11px 18px;cursor:pointer;transition:transform .1s ease,filter .15s ease;}
.btn:active{transform:scale(.97);}
.btn-blue{background:var(--blue);color:#fff;}
.btn-blue:hover{filter:brightness(1.08);}
.btn-sun{background:var(--sun);color:var(--ink);}
.btn-sun:hover{filter:brightness(1.05);}
.btn-ghost{background:var(--ocean);color:var(--blue-deep);}
.btn-big{width:100%;margin-top:14px;font-size:17px;padding:14px;}
.nav-row{display:flex;gap:8px;margin-top:14px;}
.nav-row .btn{flex:1;font-size:16px;padding:13px;}
.saved-note{margin-top:10px;font-size:13.5px;color:var(--green);font-weight:700;display:none;}
.legend{margin-top:14px;border-top:1.5px dashed var(--line);padding-top:12px;font-size:13px;color:#54718A;display:flex;gap:14px;flex-wrap:wrap;}
.legend i{display:inline-block;width:13px;height:13px;border-radius:3px;vertical-align:-2px;margin-right:5px;border:1px solid #9FB6C4;}
.legend .l-white{background:var(--land);} .legend .l-yellow{background:var(--sun);} .legend .l-blue{background:var(--blue-soft);}
.hint-mini{margin-top:10px;font-size:12.5px;color:#7A93A6;line-height:1.5;}

/* 결과 */
.result-hero{position:relative;background:var(--paper);border:2px solid var(--line);border-radius:var(--radius);
  padding:32px 22px;text-align:center;margin-bottom:16px;}
.stamp{position:absolute;top:14px;right:16px;transform:rotate(9deg);border:3px double var(--coral);color:var(--coral);
  border-radius:12px;font-size:13px;font-weight:900;letter-spacing:.2em;padding:7px 11px;}
.result-name{display:inline-block;font-size:15px;font-weight:800;color:#8A6207;background:var(--sun-soft);
  border:1.5px solid var(--sun);border-radius:999px;padding:6px 16px;margin-bottom:12px;}
.score-big{font-size:clamp(42px,8vw,68px);font-weight:900;color:var(--blue);line-height:1.1;}
.score-big .total{font-size:.45em;color:#7A93A6;font-weight:800;}
.score-msg{margin-top:8px;font-size:17px;font-weight:700;}
.world-summary{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:16px;}
.ws-item{font-size:13.5px;font-weight:800;background:var(--ocean);border:1.5px solid var(--line);
  border-radius:999px;padding:6px 13px;color:var(--blue-deep);}
.tabbar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;}
.tab{font-family:inherit;font-size:14px;font-weight:800;border:2px solid var(--line);background:var(--paper);
  color:#54718A;border-radius:999px;padding:8px 15px;cursor:pointer;}
.tab.active{border-color:var(--blue);background:var(--blue);color:#fff;}
.result-layout{display:grid;grid-template-columns:1.35fr .65fr;gap:16px;align-items:start;}
@media (max-width:900px){.result-layout{grid-template-columns:1fr;}}
.result-list h3{font-size:15px;margin:2px 0 8px;display:flex;align-items:center;gap:8px;}
.badge{font-size:12px;font-weight:800;border-radius:999px;padding:3px 10px;}
.badge.ok{background:var(--green-soft);color:var(--green);}
.badge.miss{background:var(--coral-soft);color:#A83E1F;}
.badge.gray{background:#ECEFF1;color:#5A7185;}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;max-height:220px;overflow-y:auto;}
.chip{display:inline-flex;align-items:center;background:var(--ocean);border:1px solid var(--line);border-radius:999px;
  padding:5px 11px;font-size:13.5px;font-weight:700;}
.chip.ok{background:var(--green-soft);border-color:#BFE3CD;color:#1E6B41;}
.chip.miss{background:var(--coral-soft);border-color:#F2C9BA;color:#A83E1F;}
.chip.gray{background:#F0F2F4;border-color:#D4DCE2;color:#5A7185;}
.empty-note{color:#9AB0C0;font-size:13.5px;}
.reveal-tip{font-size:12.5px;color:#7A93A6;margin-top:6px;}

.home-fab{position:fixed;right:22px;bottom:22px;z-index:40;display:none;align-items:center;gap:8px;
  background:var(--ink);color:#fff;font-size:16px;font-weight:800;border:none;border-radius:999px;
  padding:14px 22px;cursor:pointer;box-shadow:0 8px 20px rgba(23,50,74,.3);font-family:inherit;transition:transform .12s ease;}
.home-fab:hover{transform:translateY(-2px);}
.home-fab.show{display:inline-flex;}

.toast{position:fixed;left:50%;bottom:92px;transform:translateX(-50%);background:var(--ink);color:#fff;
  font-size:14px;font-weight:700;padding:10px 20px;border-radius:999px;opacity:0;pointer-events:none;transition:opacity .25s;z-index:50;}
.toast.show{opacity:1;}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;}}
</style>
</head>
<body>
<div class="wrap">

  <!-- 1. 시작: 이름 + 대륙 선택 -->
  <section id="screen-select" class="screen active">
    <header>
      <span class="eyebrow">CLICK & NAME QUIZ</span>
      <h1>지도를 클릭해 <span class="accent">나라 이름</span>을 맞혀요!</h1>
      <p class="sub">이름을 적고 대륙을 고른 뒤, 지도에서 나라를 클릭해 이름을 입력하세요.</p>
    </header>
    <div class="name-card">
      <label for="playerName">EXPLORER NAME · 탐험가 이름</label>
      <div class="name-row">
        <input type="text" id="playerName" placeholder="이름을 입력하세요 (예: 김샛별)" autocomplete="off" maxlength="20" enterkeyhint="done">
      </div>
      <p class="name-hint">이름을 적은 뒤 아래에서 탐험할 대륙을 클릭하면 바로 시작돼요!</p>
    </div>
    <div class="grid" id="continentGrid"></div>
  </section>

  <!-- 2. 퀴즈 -->
  <section id="screen-quiz" class="screen">
    <div class="quiz-head">
      <div class="quiz-title"><small id="quizEyebrow">CONTINENT</small><span id="quizTitle"></span></div>
      <div class="pills">
        <span class="pill name" id="namePill"></span>
        <span class="pill"><span id="answeredCount">0</span> / <span id="totalCount">0</span> 답변</span>
      </div>
    </div>
    <div class="quiz-layout">
      <div class="panel map-panel" id="quizMapPanel"></div>
      <div class="side-sticky">
        <div class="panel">
          <div class="ask-box" id="askBox"></div>
          <div id="quizButtons"></div>
          <div class="legend">
            <span><i class="l-white"></i>아직 안 함</span>
            <span><i class="l-yellow"></i>선택됨</span>
            <span><i class="l-blue"></i>답변 완료</span>
          </div>
          <p class="hint-mini" id="quizHint"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 결과 -->
  <section id="screen-result" class="screen">
    <div class="result-hero">
      <div class="stamp">탐험 완료</div>
      <div><span class="result-name" id="resultName"></span></div>
      <div class="score-big"><span id="scoreNum">0</span><span class="total"> / <span id="scoreTotal">0</span>개 정답</span></div>
      <p class="score-msg" id="scoreMsg"></p>
      <div class="world-summary" id="worldSummary" style="display:none;"></div>
    </div>
    <div class="tabbar" id="tabBar" style="display:none;"></div>
    <div class="result-layout">
      <div class="panel map-panel" id="resultMapPanel"></div>
      <div class="panel result-list">
        <h3>맞힌 나라 <span class="badge ok" id="okBadge">0</span></h3>
        <div class="chips" id="okChips"></div>
        <h3>틀린 나라 <span class="badge miss" id="badBadge">0</span></h3>
        <div class="chips" id="badChips"></div>
        <h3>답하지 않은 나라 <span class="badge gray" id="noneBadge">0</span></h3>
        <div class="chips" id="noneChips"></div>
        <button class="btn btn-ghost" id="revealBtn">지도에 정답 이름 표시하기</button>
        <p class="reveal-tip">결과 지도의 나라 위에 마우스를 올려도 정답을 볼 수 있어요.</p>
      </div>
    </div>
  </section>

</div>

<button class="home-fab" id="homeBtn">🏠 처음으로</button>
<div class="toast" id="toast"></div>

