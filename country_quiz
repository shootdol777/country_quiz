"키르기스스탄":["키르기즈스탄","키르기스탄"],"카자흐스탄":["카자흐"],"우즈베키스탄":["우즈벡","우즈베크스탄"],
"방글라데시":["방글라데쉬"],"러시아":["러시아연방"],
"영국":["그레이트브리튼","연합왕국"],"체코":["체키아","체코공화국"],"북마케도니아":["마케도니아"],
"보스니아헤르체고비나":["보스니아"],"바티칸":["바티칸시국","교황청"],"스페인":["에스파냐"],"네덜란드":["홀란드","화란"],
"독일":["독일연방공화국"],"이탈리아":["이태리"],"포르투갈":["포르투칼"],"그리스":["그리이스"],
"코트디부아르":["아이보리코스트"],"콩고민주공화국":["민주콩고","dr콩고","콩고민주"],"콩고공화국":["콩고"],
"중앙아프리카공화국":["중앙아프리카"],"남아프리카공화국":["남아공"],"에스와티니":["스와질란드","스와질랜드"],
"카보베르데":["카포베르데"],"상투메프린시페":["상토메프린시페"],"이집트":["이집트아랍공화국"],
"미국":["미합중국","아메리카합중국"],"멕시코":["멕시코합중국"],"캐나다":["카나다"],"도미니카연방":["도미니카"],
"세인트빈센트그레나딘":["세인트빈센트"],"세인트키츠네비스":["세인트크리스토퍼네비스"],
"앤티가바부다":["안티구아바부다","앤티가바뷰다"],"트리니다드토바고":["트리니다드"],
"호주":["오스트레일리아"],"미크로네시아연방":["미크로네시아"],"솔로몬제도":["솔로몬"],"마셜제도":["마샬제도","마셜군도"],
};
function norm(s){return s.toLowerCase().replace(/[\s·ㆍ\-'’.]/g,"");}
const ACCEPT = {};
for(const cid of ORDER){
  for(const c of MAPS[cid].countries){
    if(ACCEPT[c.ko]) continue;
    const set = new Set([norm(c.ko)]);
    for(const a of (ALIASES[c.ko]||[])) set.add(norm(a));
    ACCEPT[c.ko] = set;
  }
}
// 전 세계 고유 국가 수 (러시아·튀르키예·이집트는 두 대륙에 나오지만 1개로 셈)
const WORLD_TOTAL = Object.keys(ACCEPT).length;

const $ = id => document.getElementById(id);
const screens = {select:$("screen-select"), quiz:$("screen-quiz"), result:$("screen-result")};
const homeBtn = $("homeBtn");
function show(name){
  Object.values(screens).forEach(s=>s.classList.remove("active"));
  screens[name].classList.add("active");
  homeBtn.classList.toggle("show", name!=="select");
  window.scrollTo({top:0});
}
const toast = $("toast"); let toastTimer=null;
function showToast(msg){
  toast.textContent=msg; toast.classList.add("show");
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>toast.classList.remove("show"),1700);
}

const SVGNS = "http://www.w3.org/2000/svg";
function buildMapSVG(cid){
  const m = MAPS[cid];
  const svg = document.createElementNS(SVGNS,"svg");
  svg.setAttribute("viewBox",`0 0 ${m.w} ${m.h}`);
  for(const g of m.gray){
    const p = document.createElementNS(SVGNS,"path");
    p.setAttribute("d",g); p.setAttribute("class","grayland");
    svg.appendChild(p);
  }
  for(const c of m.countries){
    if(c.d){
      const p = document.createElementNS(SVGNS,"path");
      p.setAttribute("d",c.d); p.setAttribute("class","country");
      p.dataset.ko = c.ko;
      svg.appendChild(p);
    }
    if(c.tiny){
      const circ = document.createElementNS(SVGNS,"circle");
      circ.setAttribute("cx",c.cx); circ.setAttribute("cy",c.cy); circ.setAttribute("r",7);
      circ.setAttribute("class","country tinydot");
      circ.dataset.ko = c.ko;
      svg.appendChild(circ);
    }
  }
  return svg;
}

/* ── 상태 ── */
let playerName="";
let mode="single";      // "single" | "world"
let current=null;       // 현재 대륙 id
let worldIdx=0;         // world 모드에서 몇 번째 대륙인지
let answers={};         // ko -> 입력한 답 (world 모드에서는 전 대륙 공유)
let selected=null, quizSvg=null;

/* ── 1. 시작 화면 ── */
function getName(){
  const v = $("playerName").value.trim();
  if(!v){
    showToast("먼저 탐험가 이름을 적어 주세요!");
    $("playerName").focus();
    return null;
  }
  return v;
}
const grid = $("continentGrid");
// 전체 대륙 카드
{
  const btn = document.createElement("button");
  btn.className="card world";
  btn.innerHTML = `
    <div class="world-inner">
      <span class="globe">🌍</span>
      <span>
        <span class="wtitle">전체 대륙 한 바퀴</span>
        <div class="wdesc">아시아부터 오세아니아까지 6개 대륙을 차례로 탐험해요. 마지막 대륙에서 제출!</div>
      </span>
      <span class="count">전 세계 ${WORLD_TOTAL}개국</span>
    </div>`;
  btn.addEventListener("click",()=>{
    const n = getName(); if(!n) return;
    playerName=n; mode="world"; worldIdx=0; answers={};
    openContinent(ORDER[0]);
  });
  grid.appendChild(btn);
}
// 대륙별 카드
for(const cid of ORDER){
  const m = MAPS[cid];
  const btn = document.createElement("button");
  btn.className="card";
  const thumb = document.createElement("div"); thumb.className="thumb";
  const mini = buildMapSVG(cid);
  mini.querySelectorAll(".country").forEach(el=>{el.style.pointerEvents="none";});
  thumb.appendChild(mini);
  const row = document.createElement("div"); row.className="row";
  row.innerHTML = `<span class="cname">${m.name}</span><span class="count">나라 ${m.countries.length}개</span>`;
  btn.append(thumb,row);
  btn.addEventListener("click",()=>{
    const n = getName(); if(!n) return;
    playerName=n; mode="single"; answers={};
    openContinent(cid);
  });
  grid.appendChild(btn);
}
$("playerName").addEventListener("keydown",e=>{
  if(e.key==="Enter"&&!e.isComposing){ e.preventDefault(); showToast("아래에서 탐험할 대륙을 골라 주세요!"); }
});

/* ── 2. 퀴즈 ── */
function openContinent(cid){
  current=cid; selected=null;
  const m = MAPS[cid];
  $("namePill").textContent = "🧭 " + playerName;
  if(mode==="world"){
    $("quizEyebrow").textContent = `WORLD TOUR · 대륙 ${worldIdx+1} / ${ORDER.length}`;
    $("quizHint").textContent = "답을 적은 나라를 다시 클릭하면 고칠 수 있어요. 러시아·튀르키예·이집트처럼 두 대륙에 걸친 나라는 한 번만 답하면 두 지도에 모두 적용됩니다.";
  }else{
    $("quizEyebrow").textContent = "CONTINENT";
    $("quizHint").textContent = "답을 적은 나라를 다시 클릭하면 고칠 수 있어요. 모든 나라를 답하지 않아도 제출할 수 있습니다.";
  }
  $("quizTitle").textContent = m.name + "의 나라들";
  $("totalCount").textContent = m.countries.length;
  const panel = $("quizMapPanel");
  panel.innerHTML="";
  quizSvg = buildMapSVG(cid);
  quizSvg.addEventListener("click",e=>{
    const t = e.target.closest(".country");
    if(t) selectCountry(t.dataset.ko);
    else deselect();
  });
  panel.appendChild(quizSvg);
  renderButtons();
  paintQuiz();
  renderAsk();
  show("quiz");
}

function renderButtons(){
  const box = $("quizButtons");
  box.innerHTML="";
  if(mode==="single"){
    const b = document.createElement("button");
    b.className="btn btn-sun btn-big"; b.textContent="제출하기 ✓";
    b.addEventListener("click",trySubmit);
    box.appendChild(b);
    return;
  }
  const row = document.createElement("div"); row.className="nav-row";
  if(worldIdx>0){
    const prev = document.createElement("button");
    prev.className="btn btn-ghost"; prev.textContent="← 이전 대륙";
    prev.addEventListener("click",()=>{ worldIdx--; openContinent(ORDER[worldIdx]); });
    row.appendChild(prev);
  }
  if(worldIdx < ORDER.length-1){
    const next = document.createElement("button");
    next.className="btn btn-blue"; next.textContent="다음 대륙 →";
    next.addEventListener("click",()=>{ worldIdx++; openContinent(ORDER[worldIdx]); });
    row.appendChild(next);
  }else{
    const submit = document.createElement("button");
    submit.className="btn btn-sun"; submit.textContent="제출하기 ✓";
    submit.addEventListener("click",trySubmit);
    row.appendChild(submit);
  }
  box.appendChild(row);
}

function paintQuiz(){
  quizSvg.querySelectorAll(".country").forEach(el=>{
    const ko = el.dataset.ko;
    el.classList.toggle("answered", ko in answers);
    el.classList.toggle("selected", ko===selected);
  });
  const m = MAPS[current];
  const n = m.countries.filter(c=>c.ko in answers).length;
  $("answeredCount").textContent = n;
}
function selectCountry(ko){ selected=ko; paintQuiz(); renderAsk(); }
function deselect(){ selected=null; paintQuiz(); renderAsk(); }

function renderAsk(){
  const box = $("askBox");
  if(!selected){
    box.innerHTML = `<p class="ask-empty">👆 지도에서 <b>나라를 클릭</b>하면<br>이곳에서 이름을 입력할 수 있어요.<br><br>작은 나라는 <b>동그라미(○)</b>를 클릭!</p>`;
    return;
  }
  const prev = answers[selected] || "";
  box.innerHTML = `
    <p class="ask-label">SELECTED COUNTRY</p>
    <p class="ask-q">노랗게 칠해진 이 나라의 이름은?</p>
    <div class="input-row">
      <input type="text" id="nameInput" placeholder="나라 이름 입력" autocomplete="off" value="${prev.replace(/"/g,'&quot;')}" enterkeyhint="done">
      <button class="btn btn-blue" id="saveBtn">${prev?"고치기":"입력"}</button>
    </div>
    <p class="saved-note" id="savedNote">✓ 저장됐어요! 다음 나라를 클릭하세요.</p>`;
  const input = $("nameInput");
  const save = ()=>{
    const v = input.value.trim();
    if(!v){ showToast("나라 이름을 입력해 주세요!"); input.focus(); return; }
    answers[selected]=v;
    $("savedNote").style.display="block";
    selected=null;
    paintQuiz();
    setTimeout(()=>{ if(!selected) renderAsk(); }, 600);
  };
  $("saveBtn").addEventListener("click",save);
  input.addEventListener("keydown",e=>{
    if(e.key==="Enter"&&!e.isComposing){e.preventDefault();save();}
  });
  input.focus(); input.select();
}

/* ── 3. 채점 ── */
function trySubmit(){
  if(Object.keys(answers).length===0){
    showToast("나라를 클릭해 한 개 이상 답해 주세요!");
    return;
  }
  grade();
}

function gradeContinent(cid){
  const m = MAPS[cid];
  const status={}; const okList=[], badList=[], noneList=[];
  for(const c of m.countries){
    const a = answers[c.ko];
    if(a===undefined){ status[c.ko]="none"; noneList.push(c.ko); continue; }
    if(ACCEPT[c.ko].has(norm(a))){ status[c.ko]="ok"; okList.push(c.ko); }
    else { status[c.ko]="bad"; badList.push({ko:c.ko, wrote:a}); }
  }
  return {status, okList, badList, noneList, total:m.countries.length};
}

let resultData={}, revealed=new Set();

function grade(){
  resultData={}; revealed=new Set();
  const cids = (mode==="world") ? ORDER : [current];
  for(const cid of cids) resultData[cid] = gradeContinent(cid);

  // 총점
  let score, total, title;
  if(mode==="world"){
    // 고유 국가 기준(두 대륙에 걸친 나라는 1개로)
    const okSet = new Set();
    for(const cid of cids) for(const k of resultData[cid].okList) okSet.add(k);
    score = okSet.size; total = WORLD_TOTAL;
    title = "전 세계";
  }else{
    score = resultData[current].okList.length;
    total = resultData[current].total;
    title = MAPS[current].name;
  }
  $("resultName").textContent = "🧭 " + playerName + " 탐험가의 기록";
  $("scoreNum").textContent = score;
  $("scoreTotal").textContent = total;
  const pct = score/total;
  let msg;
  if(pct===1) msg=`완벽해요! ${title}의 모든 나라를 맞혔어요! 🏆`;
  else if(pct>=0.7) msg=`대단해요! ${title} 지리 박사가 눈앞이에요! 🌟`;
  else if(pct>=0.4) msg=`잘했어요! 틀린 나라를 확인하면 더 강해져요! 💪`;
  else msg=`좋은 시작이에요! 정답을 확인하고 다시 도전해 볼까요? 🚀`;
  $("scoreMsg").textContent = msg;

  // 전체 모드: 대륙별 요약 + 탭
  const ws=$("worldSummary"), tb=$("tabBar");
  if(mode==="world"){
    ws.style.display="flex"; ws.innerHTML="";
    tb.style.display="flex"; tb.innerHTML="";
    for(const cid of ORDER){
      const r = resultData[cid];
      const s=document.createElement("span");
      s.className="ws-item";
      s.textContent=`${MAPS[cid].name} ${r.okList.length}/${r.total}`;
      ws.appendChild(s);
      const t=document.createElement("button");
      t.className="tab"; t.dataset.cid=cid;
      t.textContent=`${MAPS[cid].name} ${r.okList.length}/${r.total}`;
      t.addEventListener("click",()=>showResultContinent(cid));
      tb.appendChild(t);
    }
  }else{
    ws.style.display="none"; tb.style.display="none";
  }
  showResultContinent(mode==="world" ? ORDER[0] : current);
  show("result");
}

function showResultContinent(cid){
  document.querySelectorAll(".tab").forEach(t=>t.classList.toggle("active", t.dataset.cid===cid));
  const r = resultData[cid];
  // 지도
  const panel=$("resultMapPanel");
  panel.innerHTML="";
  const svg = buildMapSVG(cid);
  svg.querySelectorAll(".country").forEach(el=>{
    const ko = el.dataset.ko;
    el.classList.add(r.status[ko]);
    const t = document.createElementNS(SVGNS,"title");
    const a = answers[ko];
    t.textContent = ko + (r.status[ko]==="bad" ? ` (내 답: ${a})` : "");
    el.appendChild(t);
  });
  const addLabels=()=>{
    for(const c of MAPS[cid].countries){
      if(r.status[c.ko]==="ok") continue;
      const label=document.createElementNS(SVGNS,"text");
      label.setAttribute("x",c.cx); label.setAttribute("y",c.cy);
      label.setAttribute("text-anchor","middle");
      label.setAttribute("class","namelabel");
      label.textContent=c.ko;
      svg.appendChild(label);
    }
  };
  if(revealed.has(cid)) addLabels();
  panel.appendChild(svg);

  // 목록
  $("okBadge").textContent=r.okList.length;
  $("badBadge").textContent=r.badList.length;
  $("noneBadge").textContent=r.noneList.length;
  const fill=(id,arr,cls,fmt)=>{
    const box=$(id); box.innerHTML="";
    if(arr.length===0){box.innerHTML=`<span class="empty-note">없어요!</span>`;return;}
    for(const x of arr){
      const s=document.createElement("span");
      s.className="chip "+cls; s.textContent=fmt(x);
      box.appendChild(s);
    }
  };
  fill("okChips",r.okList,"ok",x=>"✓ "+x);
  fill("badChips",r.badList,"miss",x=>`${x.ko} (내 답: ${x.wrote})`);
  fill("noneChips",r.noneList,"gray",x=>x);

  const revealBtn=$("revealBtn");
  revealBtn.style.display = revealed.has(cid) ? "none" : "inline-block";
  revealBtn.onclick=()=>{
    revealed.add(cid);
    addLabels();
    revealBtn.style.display="none";
  };
}

/* ── 처음으로 ── */
homeBtn.addEventListener("click",()=>{
  current=null; answers={}; selected=null; mode="single"; worldIdx=0;
  show("select");
  $("playerName").focus();
});
</script>
